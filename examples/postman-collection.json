{
  "info": {
    "name": "Response Crypt API",
    "description": "Postman collection for testing Response Crypt package",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Encrypted Response",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/secure-data",
          "host": ["{{base_url}}"],
          "path": ["api", "secure-data"]
        },
        "description": "Get data with encrypted response"
      }
    },
    {
      "name": "Send Encrypted Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payload\": \"eyJpdiI6IjRGNnNMOEV...\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/process",
          "host": ["{{base_url}}"],
          "path": ["api", "process"]
        },
        "description": "Send encrypted request payload"
      }
    },
    {
      "name": "Secure Transaction",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payload\": \"{{encrypted_payload}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/secure-transaction",
          "host": ["{{base_url}}"],
          "path": ["api", "secure-transaction"]
        },
        "description": "Send and receive encrypted transaction data"
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "encrypted_payload",
      "value": "",
      "type": "string"
    }
  ]
}
