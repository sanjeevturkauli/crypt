{
    "name": "securecrypto/laravel-encryption",
    "description": "Professional Laravel package for secure encryption with Strategy Pattern, SOLID principles, and modern PHP 8.2+ features",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "encryption",
        "api",
        "security",
        "response",
        "request",
        "decrypt",
        "encrypt",
        "strategy-pattern",
        "solid-principles",
        "php8",
        "modern-php",
        "design-patterns",
        "hex-encoding",
        "mobile"
    ],
    "authors": [
        {
            "name": "Sanjeev Kumar",
            "email": "radhe1310143@gmail.com",
            "homepage": "https://kartikgroupofindia.com/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/encryption": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "SecureCrypto\\Encryption\\": "src/"
        },
        "files": [
            "src/Helpers/ResponseCryptHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "SecureCrypto\\Encryption\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SecureCrypto\\Encryption\\ResponseCryptServiceProvider"
            ],
            "aliases": {
                "ResponseCrypt": "SecureCrypto\\Encryption\\Facades\\ResponseCrypt"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "post-package-uninstall": [
            "@php artisan secure-crypto:cleanup --force"
        ]
    }
}